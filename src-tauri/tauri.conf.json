{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "devPath": "http://127.0.0.1:5173",
    "distDir": "../frontend/dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "智能数据分析平台",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": true },
      "dialog": { "all": false, "open": true },
      "process": { "all": false, "exit": true, "relaunch": true }
    },
    "bundle": {
      "active": true,
      "targets": ["msi", "nsis"],
      "identifier": "com.datafusionx.desktop",
      "icon": ["icons/icon.ico", "icons/icon.png"],
      "resources": ["../backend-dist/**", "../frontend/dist/**"],
      "windows": {
        "wix": { "language": ["zh-CN"] }
      }
    },
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "title": "智能数据分析平台",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 760,
        "fullscreen": false,
        "resizable": true
      }
    ]
  }
}
